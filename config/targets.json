    "poseidon2_cryptanalysis_trackb_fast": {
      "type": "command",
      "description": "Deterministic reduced-round Poseidon cryptanalysis search (fast budget)",
      "project_dir": ".",
      "source_file": "config/track_b_attack_config.json",
      "language": "JSON",
      "metric_name": "attack_score",
      "higher_is_better": true,
      "min_improvement_rel": 0.0,
      "min_improvement_rel_mode": "fixed",
      "confirm_repeats": 1,
      "ab_repeats": 1,
      "blocked_mutation_ttl": 4,
      "mutation_schedule": "ucb",
      "mutation_ucb_explore": 0.55,
      "benchmark_command": [
        "python3",
        "attack_harness.py",
        "--config",
        "config/track_b_attack_config.json",
        "--mode",
        "fast",
        "--output-format",
        "json"
      ],
      "warmup_runs": 0,
      "runs": 3,
      "aggregate": "median",
      "metric_source": "json_stdout",
      "metric_json_path": "metrics.attack_score"
    },
