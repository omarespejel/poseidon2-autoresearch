    "leanmultisig_poseidon16_fast": {
      "type": "command",
      "description": "Lean multisig Poseidon16 prover throughput (fast smoke profile)",
      "project_dir": "work/leanMultisig",
      "metric_name": "poseidons_per_s",
      "higher_is_better": true,
      "min_improvement_rel": 0.01,
      "max_rel_stdev": 0.15,
      "confirm_repeats": 1,
      "benchmark_command": [
        "cargo",
        "run",
        "--release",
        "--",
        "poseidon",
        "--log-n-perms",
        "11"
      ],
      "warmup_runs": 1,
      "runs": 3,
      "aggregate": "median",
      "metric_regex": "([0-9]+) Poseidons / s",
      "bootstrap": {
        "git_url": "https://github.com/leanEthereum/leanMultisig.git",
        "path": "work/leanMultisig",
        "ref": "6f06c021823c742697bf867bd53d0501b66289fe"
      }
    },
